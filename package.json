{
  "name": "@rayriffy/analytics",
  "version": "0.0.1",
  "author": "Phumrapee Limpianchop <mail@rayriffy.com>",
  "description": "Prebuilt analytics tool",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.cjs",
      "import": "./dist/index.js"
    }
  },
  "repository": {
    "url": "git+https://github.com/rayriffy/analytics"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "files": ["src", "dist"],
  "scripts": {
    "preinstall": "npx only-allow bun",
    "test": "vitest",
    "coverage": "vitest run --coverage",
    "dev": "bun run build --watch",
    "build": "tsup",
    "prepare": "bun run build"
  },
  "keywords": [],
  "dependencies": {
    "winston": "3.17.0",
    "winston-loki": "6.1.3"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "@changesets/cli": "2.29.2",
    "@tsconfig/node22": "22.0.1",
    "tsup": "8.4.0",
    "typescript": "5.8.3"
  }
}
